{
    "name": "xul/laravel-project-map",
    "description": "Laravel package for generating project structure maps",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael Erastus"
        }
    ],
    "autoload": {
        "psr-4": {
            "Xul\\ProjectMap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Xul\\ProjectMap\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Xul\\ProjectMap\\ProjectMapServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "11.5.50",
        "pestphp/pest": "3.8.6"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
